# ═══════════════════════════════════════════════
#  SAMS 后端环境配置
#  复制此文件为 .env 并按实际环境修改
# ═══════════════════════════════════════════════

# ── 数据库 ──────────────────────────────────────
POSTGRES_SERVER=localhost
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=sams

# ── Redis ────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ── 对象存储 ─────────────────────────────────────
# 可选值: local | minio | aws | alioss
STORAGE_TYPE=minio

# MinIO 连接配置（与 docker-compose.yml 保持一致）
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false
# MinIO 对外访问基础 URL（浏览器可直接访问的地址）
MINIO_PUBLIC_URL=http://localhost:9000

# 本地存储根目录（STORAGE_TYPE=local 时使用）
STORAGE_LOCAL_ROOT=./storage_data

# ── 安全 ─────────────────────────────────────────
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── CORS（逗号分隔，生产环境必须收紧）───────────
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:3001"]

# ── 初始化数据 ──────────────────────────────────────
ADMIN_EMAIL=admin@sams.local
ADMIN_PASSWORD=Admin@2024
SKIP_SEED=false

# ── AI / Dify ─────────────────────────────────────
DIFY_BASE_URL=http://localhost/v1
DIFY_API_KEY=app-ZfCaT8FmlQ0JF8zCN0cDQxRG
