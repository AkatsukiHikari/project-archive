# ============================================================
# SAMS 环境变量配置模板
# 复制此文件为 .env 并填入真实值
# ============================================================

# ── 数据库 ──────────────────────────────────────────────────
POSTGRES_SERVER=localhost
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=sams
# 也可直接指定完整连接串（优先级更高）
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost/sams

# ── Redis ────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ── 安全（必填，生产环境请使用随机长字符串） ─────────────────
# 生成命令：python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Token 有效期（分钟），默认 1 天
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── CORS（多个地址用逗号分隔） ───────────────────────────────
# 本地开发
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:3001"]

# ── 对象存储 ─────────────────────────────────────────────────
# 可选值：local | minio | aws | alioss
STORAGE_TYPE=local
STORAGE_LOCAL_ROOT=./storage_data

# MinIO（STORAGE_TYPE=minio 时必填）
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false
MINIO_PUBLIC_URL=http://localhost:9000

# AWS S3（STORAGE_TYPE=aws 时必填）
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# AWS_BUCKET_NAME=sams-archive

# 阿里云 OSS（STORAGE_TYPE=alioss 时必填）
# OSS_ACCESS_KEY_ID=
# OSS_ACCESS_KEY_SECRET=
# OSS_ENDPOINT=

# ── Elasticsearch ────────────────────────────────────────────
ELASTICSEARCH_URL=http://localhost:9200

# ── RabbitMQ / Celery ───────────────────────────────────────
RABBITMQ_URL=amqp://guest:guest@localhost:5672//

# ── AI / RAG ─────────────────────────────────────────────────
# Ollama 本地服务地址
OLLAMA_BASE_URL=http://localhost:11434
# 对话模型（推荐 qwen2.5:7b 或 qwen2.5:14b）
OLLAMA_CHAT_MODEL=qwen2.5:7b
# 向量化模型
OLLAMA_EMBED_MODEL=nomic-embed-text
# 向量维度（nomic-embed-text 为 768）
EMBEDDING_DIMENSION=768

# Dify 本地服务
DIFY_BASE_URL=http://localhost/v1
# Dify 应用 API Key（在 Dify 后台创建应用后获取）
DIFY_API_KEY=
